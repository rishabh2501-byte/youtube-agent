# AI YouTube Agent - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Configuration (Choose one or both)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Preferred LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# =============================================================================
# Text-to-Speech Configuration
# =============================================================================
# ElevenLabs (Recommended for natural voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI TTS (Alternative)
# Voice options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=onyx

# Preferred TTS provider: "elevenlabs" or "openai"
TTS_PROVIDER=elevenlabs

# =============================================================================
# Stock Footage Configuration
# =============================================================================
PEXELS_API_KEY=your_pexels_api_key_here

# =============================================================================
# Image Generation Configuration
# =============================================================================
# Preferred thumbnail generator: "dalle" or "stable_diffusion"
IMAGE_GENERATOR=dalle

# Stable Diffusion API (if using)
STABILITY_API_KEY=your_stability_api_key_here

# =============================================================================
# YouTube API Configuration
# =============================================================================
YOUTUBE_CLIENT_SECRETS_FILE=credentials/client_secrets.json
YOUTUBE_TOKEN_FILE=credentials/youtube_token.json

# YouTube channel category ID (22 = People & Blogs, 24 = Entertainment, 28 = Science & Tech)
YOUTUBE_CATEGORY_ID=24

# Privacy status: public, private, unlisted
YOUTUBE_PRIVACY_STATUS=public

# =============================================================================
# Video Configuration
# =============================================================================
# Target video duration in seconds (45-60 recommended for shorts)
VIDEO_DURATION_SECONDS=60

# Video resolution
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# Frame rate
VIDEO_FPS=30

# =============================================================================
# Trending Configuration
# =============================================================================
# Region for trending topics (ISO 3166-1 alpha-2 country code)
TRENDING_REGION=US

# Number of trending topics to fetch
TRENDING_TOPICS_COUNT=20

# =============================================================================
# Output Configuration
# =============================================================================
OUTPUT_DIR=output

# Keep intermediate files (audio, subtitles, etc.)
KEEP_INTERMEDIATE_FILES=false

# =============================================================================
# Scheduler Configuration
# =============================================================================
# Time to run daily (24-hour format, e.g., "09:00")
SCHEDULE_TIME=09:00

# Timezone (e.g., "America/New_York", "UTC", "Asia/Kolkata")
TIMEZONE=UTC

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/youtube_agent.log
